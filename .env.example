# Auth.js / Next Auth configuration (for skill reference, but adapted for Vite)
# In Vite, variables must be prefixed with NEXT_PUBLIC_

# Health ID (moph.id.th)
NEXT_PUBLIC_HEALTH_CLIENT_ID=your_health_client_id
NEXT_PUBLIC_HEALTH_CLIENT_SECRET=your_health_client_secret
NEXT_PUBLIC_HEALTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Provider ID (provider.id.th)
NEXT_PUBLIC_PROVIDER_CLIENT_ID=your_provider_client_id
NEXT_PUBLIC_PROVIDER_CLIENT_SECRET=your_provider_client_secret

# Telegram Notifications
# 1. Talk to @BotFather to create a bot and get the token
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# 2. Get your Chat ID (e.g. by talking to @userinfobot)
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# 3. Ngrok HTTPS URL for the Telegram Web App
# Run `ngrok http 3000` and paste the Forwarding URL here (Example: https://1234.ngrok-free.app)
WEB_APP_URL="YOUR_NGROK_HTTPS_URL_HERE"
